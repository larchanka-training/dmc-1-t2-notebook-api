{
  "components": {
    "schemas": {
      "ComponentStatus": {
        "examples": [
          {
            "name": "database",
            "status": "ok"
          },
          {
            "detail": "connection refused",
            "name": "database",
            "status": "fail"
          }
        ],
        "properties": {
          "detail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Optional diagnostic message when the component is unhealthy",
            "title": "Detail"
          },
          "name": {
            "description": "Component identifier",
            "examples": [
              "database"
            ],
            "title": "Name",
            "type": "string"
          },
          "status": {
            "description": "Component status",
            "enum": [
              "ok",
              "fail"
            ],
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "name",
          "status"
        ],
        "title": "ComponentStatus",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "examples": [
          {
            "app": "MSD FastAPI Template",
            "components": [],
            "environment": "dev",
            "status": "ok",
            "version": "0.1.0"
          }
        ],
        "properties": {
          "app": {
            "description": "Application name",
            "examples": [
              "MSD FastAPI Template"
            ],
            "title": "App",
            "type": "string"
          },
          "components": {
            "description": "Per-component health checks (e.g. database)",
            "items": {
              "$ref": "#/components/schemas/ComponentStatus"
            },
            "title": "Components",
            "type": "array"
          },
          "environment": {
            "description": "Runtime environment",
            "examples": [
              "dev",
              "prod"
            ],
            "title": "Environment",
            "type": "string"
          },
          "status": {
            "description": "Overall service status",
            "enum": [
              "ok",
              "degraded"
            ],
            "title": "Status",
            "type": "string"
          },
          "version": {
            "description": "Application version",
            "examples": [
              "0.1.0"
            ],
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "status",
          "app",
          "version",
          "environment"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "LoginRequest": {
        "properties": {
          "email": {
            "description": "User email",
            "examples": [
              "user@example.com"
            ],
            "format": "email",
            "title": "Email",
            "type": "string"
          },
          "password": {
            "description": "Plain-text password",
            "title": "Password",
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "title": "LoginRequest",
        "type": "object"
      },
      "RefreshRequest": {
        "properties": {
          "refresh_token": {
            "description": "Refresh token issued at login",
            "title": "Refresh Token",
            "type": "string"
          }
        },
        "required": [
          "refresh_token"
        ],
        "title": "RefreshRequest",
        "type": "object"
      },
      "RegisterRequest": {
        "properties": {
          "email": {
            "description": "User email",
            "examples": [
              "user@example.com"
            ],
            "format": "email",
            "title": "Email",
            "type": "string"
          },
          "password": {
            "description": "Plain-text password, min 8 chars",
            "maxLength": 128,
            "minLength": 8,
            "title": "Password",
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "title": "RegisterRequest",
        "type": "object"
      },
      "TokenResponse": {
        "properties": {
          "access_token": {
            "description": "JWT access token (Bearer)",
            "title": "Access Token",
            "type": "string"
          },
          "expires_in": {
            "description": "Access token lifetime in seconds",
            "title": "Expires In",
            "type": "integer"
          },
          "refresh_token": {
            "description": "Opaque refresh token",
            "title": "Refresh Token",
            "type": "string"
          },
          "token_type": {
            "default": "bearer",
            "description": "Token type for Authorization header",
            "title": "Token Type",
            "type": "string"
          }
        },
        "required": [
          "access_token",
          "refresh_token",
          "expires_in"
        ],
        "title": "TokenResponse",
        "type": "object"
      },
      "UserResponse": {
        "properties": {
          "created_at": {
            "description": "Account creation timestamp",
            "format": "date-time",
            "title": "Created At",
            "type": "string"
          },
          "email": {
            "description": "User email",
            "format": "email",
            "title": "Email",
            "type": "string"
          },
          "id": {
            "description": "User identifier",
            "format": "uuid",
            "title": "Id",
            "type": "string"
          }
        },
        "required": [
          "id",
          "email",
          "created_at"
        ],
        "title": "UserResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "description": "JWT access token",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "contact": {
      "name": "MSD Course",
      "url": "https://github.com/larchanka-training/dmc-1-t2-notebook-api"
    },
    "description": "## MSD FastAPI Template\n\nBackend API for the JS Notebook project. Built on a multi-module architecture: each domain module owns its `controllers`, `services` and `schemas`.\n\n**Documentation:**\n- Swagger UI: [`/docs`](/docs)\n- ReDoc: [`/redoc`](/redoc)\n- OpenAPI schema: [`/openapi.json`](/openapi.json)\n",
    "license": {
      "name": "MIT"
    },
    "title": "MSD FastAPI Template",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/": {
      "get": {
        "description": "Returns a static welcome message; useful as a smoke test.",
        "operationId": "root__get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Root  Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Service welcome message",
        "tags": [
          "Root"
        ]
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "description": "Verifies credentials and returns a JWT access token and a refresh token.",
        "operationId": "login_api_v1_auth_login_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Authenticate and obtain tokens",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "description": "Invalidates the given refresh token so it can no longer be used.",
        "operationId": "logout_api_v1_auth_logout_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Revoke a refresh token",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "description": "Returns the profile of the user identified by the Bearer access token.",
        "operationId": "me_api_v1_auth_me_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "Get the current authenticated user",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/auth/refresh": {
      "post": {
        "description": "Rotates the refresh token: the old one is revoked and a new pair is issued.",
        "operationId": "refresh_api_v1_auth_refresh_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Exchange a refresh token for new tokens",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "description": "Creates an account with email and password. Email must be unique.",
        "operationId": "register_api_v1_auth_register_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Register a new user",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/health": {
      "get": {
        "description": "Returns basic application liveness information without checking external dependencies. Use this endpoint for Kubernetes `livenessProbe` to determine whether the process is alive.",
        "operationId": "healthcheck_api_v1_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "app": "MSD FastAPI Template",
                  "components": [],
                  "environment": "dev",
                  "status": "ok",
                  "version": "0.1.0"
                },
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Service is alive"
          }
        },
        "summary": "Liveness probe",
        "tags": [
          "Health"
        ]
      }
    },
    "/api/v1/health/ready": {
      "get": {
        "description": "Verifies that the application and its critical dependencies (database) are reachable. Use this endpoint for Kubernetes `readinessProbe`. Returns HTTP 200 when all critical dependencies are healthy and HTTP 503 when a dependency is unavailable.",
        "operationId": "readiness_api_v1_health_ready_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "app": "MSD FastAPI Template",
                  "components": [
                    {
                      "name": "database",
                      "status": "ok"
                    }
                  ],
                  "environment": "dev",
                  "status": "ok",
                  "version": "0.1.0"
                },
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "All components healthy"
          },
          "503": {
            "content": {
              "application/json": {
                "example": {
                  "app": "MSD FastAPI Template",
                  "components": [
                    {
                      "detail": "connection refused",
                      "name": "database",
                      "status": "fail"
                    }
                  ],
                  "environment": "dev",
                  "status": "degraded",
                  "version": "0.1.0"
                }
              }
            },
            "description": "One or more critical dependencies are unreachable"
          }
        },
        "summary": "Readiness probe",
        "tags": [
          "Health"
        ]
      }
    }
  },
  "tags": [
    {
      "description": "Service entry point.",
      "name": "Root"
    },
    {
      "description": "Liveness and readiness probes used by orchestrators (Kubernetes, Docker Compose) to monitor the service.",
      "name": "Health"
    },
    {
      "description": "User registration and authentication. Issues JWT access tokens and rotatable refresh tokens.",
      "name": "Auth"
    }
  ]
}
