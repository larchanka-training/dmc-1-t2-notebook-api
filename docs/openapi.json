{
  "components": {
    "schemas": {
      "ComponentStatus": {
        "examples": [
          {
            "name": "database",
            "status": "ok"
          },
          {
            "detail": "connection refused",
            "name": "database",
            "status": "fail"
          }
        ],
        "properties": {
          "detail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Optional diagnostic message when the component is unhealthy",
            "title": "Detail"
          },
          "name": {
            "description": "Component identifier",
            "examples": [
              "database"
            ],
            "title": "Name",
            "type": "string"
          },
          "status": {
            "description": "Component status",
            "enum": [
              "ok",
              "fail"
            ],
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "name",
          "status"
        ],
        "title": "ComponentStatus",
        "type": "object"
      },
      "HealthResponse": {
        "examples": [
          {
            "app": "MSD FastAPI Template",
            "components": [],
            "environment": "dev",
            "status": "ok",
            "version": "0.1.0"
          }
        ],
        "properties": {
          "app": {
            "description": "Application name",
            "examples": [
              "MSD FastAPI Template"
            ],
            "title": "App",
            "type": "string"
          },
          "components": {
            "description": "Per-component health checks (e.g. database)",
            "items": {
              "$ref": "#/components/schemas/ComponentStatus"
            },
            "title": "Components",
            "type": "array"
          },
          "environment": {
            "description": "Runtime environment",
            "examples": [
              "dev",
              "prod"
            ],
            "title": "Environment",
            "type": "string"
          },
          "status": {
            "description": "Overall service status",
            "enum": [
              "ok",
              "degraded"
            ],
            "title": "Status",
            "type": "string"
          },
          "version": {
            "description": "Application version",
            "examples": [
              "0.1.0"
            ],
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "status",
          "app",
          "version",
          "environment"
        ],
        "title": "HealthResponse",
        "type": "object"
      }
    }
  },
  "info": {
    "contact": {
      "name": "MSD Course",
      "url": "https://github.com/larchanka-training/dmc-1-t2-notebook-api"
    },
    "description": "## MSD FastAPI Template\n\nBackend API for the JS Notebook project. Built on a multi-module architecture: each domain module owns its `controllers`, `services` and `schemas`.\n\n**Documentation:**\n- Swagger UI: [`/docs`](/docs)\n- ReDoc: [`/redoc`](/redoc)\n- OpenAPI schema: [`/openapi.json`](/openapi.json)\n",
    "license": {
      "name": "MIT"
    },
    "title": "MSD FastAPI Template",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/": {
      "get": {
        "description": "Returns a static welcome message; useful as a smoke test.",
        "operationId": "root__get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Root  Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Service welcome message",
        "tags": [
          "Root"
        ]
      }
    },
    "/api/v1/health": {
      "get": {
        "description": "Returns basic application liveness information without checking external dependencies. Use this endpoint for Kubernetes `livenessProbe` to determine whether the process is alive.",
        "operationId": "healthcheck_api_v1_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "app": "MSD FastAPI Template",
                  "components": [],
                  "environment": "dev",
                  "status": "ok",
                  "version": "0.1.0"
                },
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Service is alive"
          }
        },
        "summary": "Liveness probe",
        "tags": [
          "Health"
        ]
      }
    },
    "/api/v1/health/ready": {
      "get": {
        "description": "Verifies that the application and its critical dependencies (database) are reachable. Use this endpoint for Kubernetes `readinessProbe`. Returns HTTP 200 when all critical dependencies are healthy and HTTP 503 when a dependency is unavailable.",
        "operationId": "readiness_api_v1_health_ready_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "app": "MSD FastAPI Template",
                  "components": [
                    {
                      "name": "database",
                      "status": "ok"
                    }
                  ],
                  "environment": "dev",
                  "status": "ok",
                  "version": "0.1.0"
                },
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "All components healthy"
          },
          "503": {
            "content": {
              "application/json": {
                "example": {
                  "app": "MSD FastAPI Template",
                  "components": [
                    {
                      "detail": "connection refused",
                      "name": "database",
                      "status": "fail"
                    }
                  ],
                  "environment": "dev",
                  "status": "degraded",
                  "version": "0.1.0"
                }
              }
            },
            "description": "One or more critical dependencies are unreachable"
          }
        },
        "summary": "Readiness probe",
        "tags": [
          "Health"
        ]
      }
    }
  },
  "tags": [
    {
      "description": "Service entry point.",
      "name": "Root"
    },
    {
      "description": "Liveness and readiness probes used by orchestrators (Kubernetes, Docker Compose) to monitor the service.",
      "name": "Health"
    }
  ]
}
