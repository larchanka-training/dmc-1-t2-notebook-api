{
  "components": {
    "schemas": {
      "ApiError": {
        "description": "Payload of a single API error.\n\nСодержимое поля ``error`` в ответе. Используется FE для\nлокализации и анализа: код (``code``) стабилен и пригоден для\n``switch``-логики, ``message`` — текст для пользователя/лога,\n``fields`` — пер-полевые ошибки валидации.",
        "properties": {
          "code": {
            "title": "Code",
            "type": "string"
          },
          "fields": {
            "additionalProperties": {
              "type": "string"
            },
            "title": "Fields",
            "type": "object"
          },
          "message": {
            "title": "Message",
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "title": "ApiError",
        "type": "object"
      },
      "ApiErrorResponse": {
        "description": "Top-level error envelope returned by the API.\n\nВнешняя «обёртка», чтобы у любого ответа об ошибке был один и тот\nже ключ верхнего уровня. Эта схема также прокидывается в OpenAPI\nкак ``responses`` для роутов, чтобы FE-генератор типов знал форму.",
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ApiError"
          }
        },
        "required": [
          "error"
        ],
        "title": "ApiErrorResponse",
        "type": "object"
      },
      "CellSchema": {
        "description": "Single notebook cell as exchanged over the API.\n\nАтомарная ячейка: код или markdown. ``updated_at`` ставит сам\nклиент (миллисекунды от эпохи) — сервер его не переписывает.\nЭто и есть основа LWW-синхронизации.",
        "properties": {
          "content": {
            "default": "",
            "maxLength": 262144,
            "title": "Content",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "kind": {
            "enum": [
              "code",
              "markdown"
            ],
            "title": "Kind",
            "type": "string"
          },
          "updatedAt": {
            "minimum": 0.0,
            "title": "Updatedat",
            "type": "integer"
          }
        },
        "required": [
          "id",
          "kind",
          "updatedAt"
        ],
        "title": "CellSchema",
        "type": "object"
      },
      "CellTombstone": {
        "description": "Tombstone record for a cell deleted on the client.\n\nКлиент шлёт «надгробие», чтобы сервер при merge мог понять: эта\nячейка удалена локально с такой-то меткой времени. Если на сервере\nта же ячейка обновилась *позже* ``deleted_at`` — удаление\nигнорируется (см. :func:`merge_cells`).",
        "properties": {
          "deletedAt": {
            "minimum": 0.0,
            "title": "Deletedat",
            "type": "integer"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          }
        },
        "required": [
          "id",
          "deletedAt"
        ],
        "title": "CellTombstone",
        "type": "object"
      },
      "ComponentStatus": {
        "description": "Health of a single dependency (e.g. database).\n\nОтражает статус одного «компонента». В minimal-варианте мы шлём\nтолько БД, но при росте сюда можно добавить кеш, очереди и т. п.",
        "examples": [
          {
            "name": "database",
            "status": "ok"
          },
          {
            "detail": "connection refused",
            "name": "database",
            "status": "fail"
          }
        ],
        "properties": {
          "detail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "Optional diagnostic message when the component is unhealthy",
            "title": "Detail"
          },
          "name": {
            "description": "Component identifier",
            "examples": [
              "database"
            ],
            "title": "Name",
            "type": "string"
          },
          "status": {
            "description": "Component status",
            "enum": [
              "ok",
              "fail"
            ],
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "name",
          "status"
        ],
        "title": "ComponentStatus",
        "type": "object"
      },
      "CurrentUser": {
        "description": "Represents the current authenticated user.\n\nDTO, который возвращает ``GET /auth/me`` и который кладётся в\nзависимостях защищённых роутов. ``alias_generator=to_camel`` нужен,\nчтобы JSON получил ``displayName`` (camelCase), а Python-код мог\nобращаться к ``display_name`` (snake_case).",
        "properties": {
          "displayName": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Displayname"
          },
          "email": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Email"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "roles": {
            "items": {
              "type": "string"
            },
            "title": "Roles",
            "type": "array"
          }
        },
        "required": [
          "id"
        ],
        "title": "CurrentUser",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "description": "Top-level health envelope returned by both probes.\n\n``status=\"ok\"`` — всё штатно; ``\"degraded\"`` — какой-то компонент\nне отвечает. Liveness-эндпоинт всегда отдаёт ``\"ok\"`` без проверок\nзависимостей, readiness — реальный агрегированный статус.",
        "examples": [
          {
            "app": "MSD FastAPI Template",
            "components": [],
            "environment": "dev",
            "status": "ok",
            "version": "0.1.0"
          }
        ],
        "properties": {
          "app": {
            "description": "Application name",
            "examples": [
              "MSD FastAPI Template"
            ],
            "title": "App",
            "type": "string"
          },
          "components": {
            "description": "Per-component health checks (e.g. database)",
            "items": {
              "$ref": "#/components/schemas/ComponentStatus"
            },
            "title": "Components",
            "type": "array"
          },
          "environment": {
            "description": "Runtime environment",
            "examples": [
              "dev",
              "prod"
            ],
            "title": "Environment",
            "type": "string"
          },
          "status": {
            "description": "Overall service status",
            "enum": [
              "ok",
              "degraded"
            ],
            "title": "Status",
            "type": "string"
          },
          "version": {
            "description": "Application version",
            "examples": [
              "0.1.0"
            ],
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "status",
          "app",
          "version",
          "environment"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "NotebookCreate": {
        "description": "Request body for ``POST /notebooks``.\n\nОтличается от ``NotebookBase`` опциональным ``id``: если клиент\nего не присылает, сервер сгенерирует ``uuid4`` сам. Если присылает —\nсоздание становится идемпотентным (см. ``NotebookService.create``).",
        "properties": {
          "cells": {
            "items": {
              "$ref": "#/components/schemas/CellSchema"
            },
            "maxItems": 500,
            "title": "Cells",
            "type": "array"
          },
          "formatVersion": {
            "default": 1,
            "minimum": 1.0,
            "title": "Formatversion",
            "type": "integer"
          },
          "id": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Id"
          },
          "title": {
            "maxLength": 255,
            "minLength": 1,
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "title"
        ],
        "title": "NotebookCreate",
        "type": "object"
      },
      "NotebookListItem": {
        "description": "Lightweight notebook row for list endpoints.\n\nНе содержит ``cells`` — только их количество. Это сильно сокращает\npayload листинга и предотвращает выгрузку больших JSONB в ответ\nна ``GET /notebooks``.",
        "properties": {
          "cellsCount": {
            "title": "Cellscount",
            "type": "integer"
          },
          "createdAt": {
            "title": "Createdat",
            "type": "integer"
          },
          "formatVersion": {
            "title": "Formatversion",
            "type": "integer"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "title": {
            "title": "Title",
            "type": "string"
          },
          "updatedAt": {
            "title": "Updatedat",
            "type": "integer"
          }
        },
        "required": [
          "id",
          "title",
          "formatVersion",
          "createdAt",
          "updatedAt",
          "cellsCount"
        ],
        "title": "NotebookListItem",
        "type": "object"
      },
      "NotebookListResponse": {
        "description": "Paginated response wrapper for ``GET /notebooks``.\n\nСтандартная «обёртка» с метаданными пагинации. ``total`` считается\nотдельным запросом и нужен фронту для построения нумерации страниц.",
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/NotebookListItem"
            },
            "title": "Items",
            "type": "array"
          },
          "limit": {
            "title": "Limit",
            "type": "integer"
          },
          "offset": {
            "title": "Offset",
            "type": "integer"
          },
          "total": {
            "title": "Total",
            "type": "integer"
          }
        },
        "required": [
          "items",
          "total",
          "limit",
          "offset"
        ],
        "title": "NotebookListResponse",
        "type": "object"
      },
      "NotebookPatch": {
        "description": "Request body for ``PATCH /notebooks/{id}``.\n\nСейчас это «full sync document», а не классический partial PATCH:\nклиент шлёт полный массив активных ``cells`` плюс ``deletedCells``\n(надгробия) — сервер делает LWW-merge. Семантически это ближе к\nPUT; решение оставить как PATCH было сознательным (Шаг 9 PR #29).",
        "properties": {
          "cells": {
            "items": {
              "$ref": "#/components/schemas/CellSchema"
            },
            "maxItems": 500,
            "title": "Cells",
            "type": "array"
          },
          "deletedCells": {
            "items": {
              "$ref": "#/components/schemas/CellTombstone"
            },
            "title": "Deletedcells",
            "type": "array"
          },
          "formatVersion": {
            "default": 1,
            "minimum": 1.0,
            "title": "Formatversion",
            "type": "integer"
          },
          "title": {
            "maxLength": 255,
            "minLength": 1,
            "title": "Title",
            "type": "string"
          }
        },
        "required": [
          "title"
        ],
        "title": "NotebookPatch",
        "type": "object"
      },
      "NotebookResponse": {
        "description": "Detailed notebook representation returned by single-item endpoints.\n\nИспользуется в ответах ``POST/GET/PATCH /notebooks/{id}``. Времена\nотдаются в миллисекундах от эпохи (UTC) — единый формат с фронтом.",
        "properties": {
          "cells": {
            "items": {
              "$ref": "#/components/schemas/CellSchema"
            },
            "maxItems": 500,
            "title": "Cells",
            "type": "array"
          },
          "createdAt": {
            "title": "Createdat",
            "type": "integer"
          },
          "formatVersion": {
            "default": 1,
            "minimum": 1.0,
            "title": "Formatversion",
            "type": "integer"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "ownerId": {
            "format": "uuid",
            "title": "Ownerid",
            "type": "string"
          },
          "title": {
            "maxLength": 255,
            "minLength": 1,
            "title": "Title",
            "type": "string"
          },
          "updatedAt": {
            "title": "Updatedat",
            "type": "integer"
          }
        },
        "required": [
          "title",
          "id",
          "ownerId",
          "createdAt",
          "updatedAt"
        ],
        "title": "NotebookResponse",
        "type": "object"
      },
      "OtpRequest": {
        "description": "Request body for starting email OTP login.",
        "properties": {
          "email": {
            "title": "Email",
            "type": "string"
          }
        },
        "required": [
          "email"
        ],
        "title": "OtpRequest",
        "type": "object"
      },
      "OtpRequestDevResponse": {
        "description": "Dev/local/test OTP response with the raw code for local testing.",
        "properties": {
          "expiresAt": {
            "title": "Expiresat",
            "type": "integer"
          },
          "otp": {
            "title": "Otp",
            "type": "string"
          }
        },
        "required": [
          "expiresAt",
          "otp"
        ],
        "title": "OtpRequestDevResponse",
        "type": "object"
      },
      "OtpVerifyRequest": {
        "description": "Request body for verifying email OTP login.",
        "properties": {
          "email": {
            "title": "Email",
            "type": "string"
          },
          "otp": {
            "maxLength": 6,
            "minLength": 6,
            "title": "Otp",
            "type": "string"
          }
        },
        "required": [
          "email",
          "otp"
        ],
        "title": "OtpVerifyRequest",
        "type": "object"
      },
      "OtpVerifyResponse": {
        "description": "Successful OTP verification response.",
        "properties": {
          "accessToken": {
            "title": "Accesstoken",
            "type": "string"
          },
          "refreshToken": {
            "title": "Refreshtoken",
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/CurrentUser"
          }
        },
        "required": [
          "accessToken",
          "refreshToken",
          "user"
        ],
        "title": "OtpVerifyResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "contact": {
      "name": "MSD Course",
      "url": "https://github.com/larchanka-training/dmc-1-t2-notebook-api"
    },
    "description": "## JS Notebook API\n\nBackend API for the JS Notebook project. Built on a multi-module architecture: each domain module owns its `controllers`, `services` and `schemas`.\n\n**Documentation:**\n- Swagger UI: [`/docs`](/docs)\n- ReDoc: [`/redoc`](/redoc)\n- OpenAPI schema: [`/openapi.json`](/openapi.json)\n",
    "license": {
      "name": "MIT"
    },
    "title": "JS Notebook API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/": {
      "get": {
        "description": "Returns a static welcome message; useful as a smoke test.",
        "operationId": "root__get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Root  Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Service welcome message",
        "tags": [
          "Root"
        ]
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "description": "Returns the current placeholder user for local development.",
        "operationId": "get_me_api_v1_auth_me_get",
        "parameters": [
          {
            "in": "header",
            "name": "X-User-Id",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "X-User-Id"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CurrentUser"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get current user",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/auth/otp/request": {
      "post": {
        "description": "Create and send an OTP for the provided email address.",
        "operationId": "request_otp_api_v1_auth_otp_request_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OtpRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OtpRequestDevResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "204": {
            "description": "OTP sent without response body"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            },
            "description": "Invalid email"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            },
            "description": "Validation error"
          }
        },
        "summary": "Request email OTP",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/auth/otp/verify": {
      "post": {
        "description": "Verify an OTP and return access/refresh tokens.",
        "operationId": "verify_otp_api_v1_auth_otp_verify_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OtpVerifyRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OtpVerifyResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            },
            "description": "Invalid email"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            },
            "description": "Invalid or expired OTP"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                }
              }
            },
            "description": "Validation error"
          }
        },
        "summary": "Verify email OTP",
        "tags": [
          "Auth"
        ]
      }
    },
    "/api/v1/health": {
      "get": {
        "description": "Returns basic application liveness information without checking external dependencies. Use this endpoint for Kubernetes `livenessProbe` to determine whether the process is alive.",
        "operationId": "healthcheck_api_v1_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "app": "MSD FastAPI Template",
                  "components": [],
                  "environment": "dev",
                  "status": "ok",
                  "version": "0.1.0"
                },
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Service is alive"
          }
        },
        "summary": "Liveness probe",
        "tags": [
          "Health"
        ]
      }
    },
    "/api/v1/health/ready": {
      "get": {
        "description": "Verifies that the application and its critical dependencies (database) are reachable. Use this endpoint for Kubernetes `readinessProbe`. Returns HTTP 200 when all critical dependencies are healthy and HTTP 503 when a dependency is unavailable.",
        "operationId": "readiness_api_v1_health_ready_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "app": "MSD FastAPI Template",
                  "components": [
                    {
                      "name": "database",
                      "status": "ok"
                    }
                  ],
                  "environment": "dev",
                  "status": "ok",
                  "version": "0.1.0"
                },
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "All components healthy"
          },
          "503": {
            "content": {
              "application/json": {
                "example": {
                  "app": "MSD FastAPI Template",
                  "components": [
                    {
                      "detail": "connection refused",
                      "name": "database",
                      "status": "fail"
                    }
                  ],
                  "environment": "dev",
                  "status": "degraded",
                  "version": "0.1.0"
                }
              }
            },
            "description": "One or more critical dependencies are unreachable"
          }
        },
        "summary": "Readiness probe",
        "tags": [
          "Health"
        ]
      }
    },
    "/api/v1/notebooks": {
      "get": {
