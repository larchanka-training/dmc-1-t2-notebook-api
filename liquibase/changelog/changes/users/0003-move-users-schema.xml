<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="users-0003-move-users-schema" author="msd">
        <comment>
            TARDIS-31: split monolithic 'app' schema by domain.
            Move app.users into its own 'users' schema. Pure DDL — no
            data is rewritten; ALTER TABLE SET SCHEMA only changes the
            namespace pointer.
        </comment>
        <sql>
            CREATE SCHEMA IF NOT EXISTS users;
            ALTER TABLE app.users SET SCHEMA users;
        </sql>

        <rollback>
            <!--
                Reverse direction only: move the table back to 'app' and
                drop the (now empty) 'users' schema. The cross-domain FK
                from notebooks.owner_id is NOT restored here — see the
                rollback note in changes/notebooks/0003-move-notebooks-schema.xml.
            -->
            <sql>
                ALTER TABLE users.users SET SCHEMA app;
                DROP SCHEMA IF EXISTS users;
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
