# FastAPI application
APP_NAME=JS Notebook API
APP_ENV=dev
API_PREFIX=/api/v1

# Local server defaults
APP_HOST=0.0.0.0
APP_PORT=8000

# Database connection for local docker-compose.
# The current API template does not use it yet, but the value is reserved for
# future persistence layer configuration.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/notebook_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=notebook_dev

# Auth/session values used by the monorepo docker-compose setup.
# Replace these values in real environments and keep production secrets outside git.
OAUTH_NAME_APPLICATION_ID=change-me
OAUTH_NAME_SECRET_KEY=change-me
TOKEN_TTL_SECONDS=86400
SESSION_TTL_SECONDS=604800

# Backend code-execution endpoint (POST /api/v1/execute).
# Disabled by default: a debug/fallback subprocess runner, NOT a production
# sandbox (docs/execution-architecture.md §12). Enabling it runs user code in a
# plain `node` child process — only do so in a trusted/dev environment.
# Hard guard: APP_ENV=production/staging + ENABLE_EXECUTE=true refuses to start
# (no hardened runtime exists yet) — see app/core/config.py.
ENABLE_EXECUTE=false
# EXECUTE_NODE_COMMAND=node
# EXECUTE_DEFAULT_TIMEOUT_MS=5000
# EXECUTE_MAX_TIMEOUT_MS=15000
# EXECUTE_MAX_CODE_BYTES=262144  # enforced by ExecutionService (operator knob)
# EXECUTE_MAX_OUTPUT_BYTES=1048576
# EXECUTE_MAX_MEMORY_MB=128
