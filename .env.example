# FastAPI application
APP_NAME=JS Notebook API
APP_ENV=dev
API_PREFIX=/api/v1

# Local server defaults
APP_HOST=0.0.0.0
APP_PORT=8000

# Database connection for local docker-compose. Used by the persistence and
# auth modules (SQLAlchemy engine).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/notebook_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=notebook_dev

# Auth/session values used by the monorepo docker-compose setup.
# Replace these values in real environments and keep production secrets outside git.
OAUTH_NAME_APPLICATION_ID=change-me
OAUTH_NAME_SECRET_KEY=change-me
TOKEN_TTL_SECONDS=86400
SESSION_TTL_SECONDS=604800

# JWT signing for the auth module. JWT_SECRET_KEY MUST be overridden in any
# real environment with a long random value (>= 32 bytes).
JWT_SECRET_KEY=dev-only-insecure-secret-change-me-in-production
JWT_ALGORITHM=HS256
